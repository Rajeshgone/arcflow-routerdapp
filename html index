<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Basic Router DApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.4/ethers.min.js"></script>
    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #1e2937);
        }
        .glass {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="min-h-screen text-white font-sans">
    <div class="max-w-md mx-auto pt-8 px-4">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center text-2xl">🔄</div>
                <h1 class="text-3xl font-bold">Router</h1>
            </div>
            <button id="connectWallet" 
                    class="px-6 py-2 bg-white text-black font-semibold rounded-2xl hover:bg-gray-200 transition">
                Connect Wallet
            </button>
        </div>

        <!-- Swap Card -->
        <div class="glass border border-white/10 rounded-3xl p-6 shadow-2xl">
            <h2 class="text-xl font-semibold mb-6 text-center">Swap Tokens</h2>

            <!-- From -->
            <div class="bg-slate-900/50 rounded-2xl p-4 mb-3">
                <div class="flex justify-between text-sm mb-3">
                    <span class="text-gray-400">You pay</span>
                    <span id="balanceFrom" class="text-gray-400">Balance: 0.00</span>
                </div>
                <div class="flex items-center gap-3">
                    <input id="amountFrom" 
                           type="text" 
                           placeholder="0.0"
                           class="bg-transparent text-3xl font-medium outline-none w-full">
                    <div onclick="selectToken('from')" 
                         id="tokenFrom"
                         class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 cursor-pointer rounded-2xl px-4 py-2">
                        <span class="text-2xl">ETH</span>
                        <span class="text-sm font-medium">ETH</span>
                        ▼
                    </div>
                </div>
            </div>

            <!-- Swap Arrow -->
            <div class="flex justify-center -my-3 relative z-10">
                <button onclick="swapTokens()" 
                        class="w-10 h-10 bg-slate-800 hover:bg-slate-700 border-4 border-slate-900 rounded-2xl flex items-center justify-center transition">
                    ↓
                </button>
            </div>

            <!-- To -->
            <div class="bg-slate-900/50 rounded-2xl p-4 mt-3">
                <div class="flex justify-between text-sm mb-3">
                    <span class="text-gray-400">You receive</span>
                    <span id="balanceTo" class="text-gray-400">Balance: 0.00</span>
                </div>
                <div class="flex items-center gap-3">
                    <input id="amountTo" 
                           type="text" 
                           placeholder="0.0"
                           class="bg-transparent text-3xl font-medium outline-none w-full">
                    <div onclick="selectToken('to')" 
                         id="tokenTo"
                         class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 cursor-pointer rounded-2xl px-4 py-2">
                        <span class="text-2xl">USDC</span>
                        <span class="text-sm font-medium">USDC</span>
                        ▼
                    </div>
                </div>
            </div>

            <!-- Rate -->
            <div class="text-xs text-gray-400 mt-4 flex justify-between items-center">
                <span>1 ETH ≈ 2,450 USDC</span>
                <span class="cursor-pointer hover:text-white" onclick="refreshRate()">⟳</span>
            </div>

            <!-- Swap Button -->
            <button onclick="executeSwap()" 
                    class="w-full mt-8 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 py-4 rounded-2xl font-bold text-lg transition">
                Swap Tokens
            </button>

            <!-- Info -->
            <div class="mt-4 text-center text-xs text-gray-500 space-y-1">
                <div>Router Fee: <span class="text-emerald-400">0.3%</span></div>
                <div id="status" class="text-amber-400"></div>
            </div>
        </div>

        <!-- Footer Info -->
        <div class="text-center text-xs text-gray-500 mt-8">
            Basic Router Demo • Powered by ethers.js<br>
            <span class="text-gray-600">Connect MetaMask to use</span>
        </div>
    </div>

    <!-- Simple Token Selector Modal -->
    <div id="tokenModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center">
        <div class="glass border border-white/10 rounded-3xl w-full max-w-sm mx-4 p-6">
            <h3 class="text-lg font-semibold mb-4">Select Token</h3>
            <div class="space-y-2 max-h-80 overflow-auto">
                <div onclick="chooseToken('ETH')" class="flex items-center gap-4 p-3 hover:bg-white/10 rounded-2xl cursor-pointer">
                    <span class="text-3xl">⛓️</span>
                    <div>
                        <div class="font-medium">Ethereum</div>
                        <div class="text-sm text-gray-400">ETH</div>
                    </div>
                </div>
                <div onclick="chooseToken('USDC')" class="flex items-center gap-4 p-3 hover:bg-white/10 rounded-2xl cursor-pointer">
                    <span class="text-3xl">💵</span>
                    <div>
                        <div class="font-medium">USD Coin</div>
                        <div class="text-sm text-gray-400">USDC</div>
                    </div>
                </div>
                <div onclick="chooseToken('DAI')" class="flex items-center gap-4 p-3 hover:bg-white/10 rounded-2xl cursor-pointer">
                    <span class="text-3xl">🔶</span>
                    <div>
                        <div class="font-medium">Dai Stablecoin</div>
                        <div class="text-sm text-gray-400">DAI</div>
                    </div>
                </div>
            </div>
            <button onclick="closeModal()" 
                    class="w-full mt-6 py-3 text-gray-400 hover:text-white border border-white/20 rounded-2xl">
                Cancel
            </button>
        </div>
    </div>

    <script>
        let provider;
        let signer;
        let fromToken = "ETH";
        let toToken = "USDC";

        const connectWalletBtn = document.getElementById('connectWallet');
        const statusEl = document.getElementById('status');

        async function connectWallet() {
            if (typeof window.ethereum !== "undefined") {
                try {
                    provider = new ethers.BrowserProvider(window.ethereum);
                    await provider.send("eth_requestAccounts", []);
                    signer = await provider.getSigner();
                    const address = await signer.getAddress();
                    connectWalletBtn.textContent = `${address.slice(0,6)}...${address.slice(-4)}`;
                    statusEl.textContent = "Wallet connected ✓";
                    console.log("Connected:", address);
                } catch (error) {
                    console.error(error);
                    statusEl.textContent = "Connection failed";
                }
            } else {
                alert("Please install MetaMask!");
            }
        }

        function selectToken(side) {
            window.currentSide = side;
            document.getElementById('tokenModal').classList.remove('hidden');
        }

        function chooseToken(token) {
            if (window.currentSide === 'from') {
                fromToken = token;
                document.getElementById('tokenFrom').innerHTML = `
                    <span class="text-2xl">${getTokenEmoji(token)}</span>
                    <span class="text-sm font-medium">${token}</span> ▼
                `;
            } else {
                toToken = token;
                document.getElementById('tokenTo').innerHTML = `
                    <span class="text-2xl">${getTokenEmoji(token)}</span>
                    <span class="text-sm font-medium">${token}</span> ▼
                `;
            }
            closeModal();
        }

        function getTokenEmoji(token) {
            if (token === 'ETH') return '⛓️';
            if (token === 'USDC') return '💵';
            if (token === 'DAI') return '🔶';
            return '🪙';
        }

        function closeModal() {
            document.getElementById('tokenModal').classList.add('hidden');
        }

        function swapTokens() {
            // Simple UI swap
            const tempToken = fromToken;
            const tempAmount = document.getElementById('amountFrom').value;
            
            fromToken = toToken;
            toToken = tempToken;
            
            document.getElementById('amountFrom').value = document.getElementById('amountTo').value || '0';
            document.getElementById('amountTo').value = tempAmount || '0';
            
            // Refresh UI
            document.getElementById('tokenFrom').innerHTML = `
                <span class="text-2xl">${getTokenEmoji(fromToken)}</span>
                <span class="text-sm font-medium">${fromToken}</span> ▼
            `;
            document.getElementById('tokenTo').innerHTML = `
                <span class="text-2xl">${getTokenEmoji(toToken)}</span>
                <span class="text-sm font-medium">${toToken}</span> ▼
            `;
        }

        async function executeSwap() {
            const amount = document.getElementById('amountFrom').value;
            if (!amount || amount === '0') {
                alert("Enter amount to swap");
                return;
            }
            if (!signer) {
                alert("Please connect wallet first");
                return;
            }
            
            statusEl.textContent = "Swapping...";
            
            // Mock transaction (demo only)
            setTimeout(() => {
                statusEl.innerHTML = `✅ Swapped ${amount} ${fromToken} to ${toToken}`;
                console.log(`Mock swap: ${amount} ${fromToken} → ${toToken}`);
            }, 1500);
        }

        function refreshRate() {
            statusEl.textContent = "Rate updated";
            setTimeout(() => statusEl.textContent = "", 2000);
        }

        // Tailwind script already included
        // Auto connect listener
        window.ethereum?.on('accountsChanged', () => window.location.reload());

        // Keyboard support
        document.getElementById('amountFrom').addEventListener('input', () => {
            // Could calculate amountTo in real app
        });
    </script>
</body>
</html>
